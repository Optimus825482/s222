# Multi-Agent Dashboard — Örnek ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.

# ── Backend (FastAPI) ─────────────────────────────────────────────
# NVIDIA API (LLM) — https://build.nvidia.com/
NVIDIA_API_KEY=

# DeepSeek API (Critic Agent) — https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# PostgreSQL (docker-compose ile kullanılıyor)
DATABASE_URL=postgresql://agent:SIFRE@localhost:5432/multiagent
POSTGRES_PASSWORD=

# Pollinations API (görsel üretim) — https://pollinations.ai/
POLLINATIONS_API_KEY=

# CORS — frontend farklı domain'deyse (örn. agent.erkanerdem.net) bu origin'i ekleyin
# Virgülle ayırarak birden fazla: CORS_ORIGINS=https://agent.erkanerdem.net,https://app.example.com
# * = tüm origin'lere izin (geliştirme için)
CORS_ORIGINS=*

# Web arama — öncelik: Tavily → Exa → Whoogle format=json
# Tavily (LLM için optimize, haber/araştırma kalitesi yüksek): https://app.tavily.com — opsiyonel
TAVILY_API_KEY=
# Exa (neural search, highlights destekli): https://exa.ai — opsiyonel
EXA_API_KEY=
# Whoogle — self-hosted Google proxy; format=json ile JSON döner, session cookie gerektirir
WHOOGLE_URL=http://whoogle-e4s8oc4kkc8sokcsco808ccw.77.42.68.4.sslip.io

# ── Frontend (Next.js) — build zamanında kullanılır ────────────────
# API ve WebSocket URL'leri (development: backend genelde 8000 veya 8001)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat

# ── Pi-AI Gateway (LLM Router) ───────────────────────────────────
# Gateway URL ve aktiflik durumu
PI_GATEWAY_URL=http://pi-gateway:3100
PI_GATEWAY_ENABLED=true
PI_GATEWAY_FALLBACK_ENABLED=true
PI_GATEWAY_FALLBACK_MAX_RETRIES=2
PI_GATEWAY_STREAMING_ENABLED=true

# LLM Provider API Keys (pi-gateway tarafından kullanılır)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ── Agentic Loop Limitleri ────────────────────────────────────────
# Agent başına maksimum iterasyon, token bütçesi ve maliyet limiti.
# Düşük değerler "budget_exceeded" guard'ını tetikler.
AGENTIC_LOOP_MAX_ITERATIONS=50
AGENTIC_LOOP_MAX_TOKENS_BUDGET=500000
AGENTIC_LOOP_MAX_COST_USD=5.00
AGENTIC_FOLLOWUP_ENABLED=true
AGENTIC_MAX_FOLLOWUPS=5
