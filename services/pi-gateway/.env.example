# Pi Gateway - LLM Provider API Keys
# Set the keys for providers you want to use. Unconfigured providers are skipped.

PORT=3100

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# Groq
GROQ_API_KEY=

# Mistral
MISTRAL_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
